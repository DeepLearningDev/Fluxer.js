{
  "name": "fluxer-js",
  "version": "0.1.0-alpha.1",
  "description": "TypeScript framework for building bots on Fluxer.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "docs/**/*",
    "CHANGELOG.md",
    "!dist/test/**"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsx src/example.ts",
    "dev:minimal": "tsx src/examples/minimal.ts",
    "start": "node dist/example.js",
    "start:minimal": "node dist/examples/minimal.js",
    "smoke:minimal": "node dist/examples/minimal.js",
    "smoke:package": "node scripts/verify-package-install.mjs",
    "lint": "eslint .",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test test/*.test.ts",
    "pack:dry-run": "npm pack --dry-run",
    "release:check": "npm run lint && npm run check && npm test && npm run build && npm run smoke:minimal && npm run smoke:package && npm run pack:dry-run",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "fluxer",
    "bot",
    "framework",
    "typescript",
    "sdk",
    "self-hosted"
  ],
  "author": "DeepLearningDev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeepLearningDev/Fluxer.js.git"
  },
  "homepage": "https://github.com/DeepLearningDev/Fluxer.js#readme",
  "bugs": {
    "url": "https://github.com/DeepLearningDev/Fluxer.js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.28.0"
  }
}
