{
  "name": "fluxer-js",
  "version": "0.1.0",
  "description": "TypeScript framework for building bots on Fluxer.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/test"
  ],
  "scripts": {
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item dist -Recurse -Force }\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsx src/example.ts",
    "start": "node dist/example.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test test/bot.test.ts"
  },
  "keywords": [
    "fluxer",
    "bot",
    "framework",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
